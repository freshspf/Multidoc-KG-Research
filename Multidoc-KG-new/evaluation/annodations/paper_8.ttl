:ConflictBankPaper :proposes :CONFLICT_BANK ;
    :contextText "we present CONFLICT BANK, the first comprehensive benchmark developed to systematically evaluate knowledge conflicts" .

:ConflictBankPaper :addresses :KnowledgeConflictsInLLMs ;
    :contextText "the critical issue of knowledge conflicts, a major source of hallucinations, has rarely been studied." .

:CONFLICT_BANK :addresses :RetrievedKnowledgeConflicts ;
    :contextText "evaluate knowledge conflicts from three aspects: (i)conflicts encountered in retrieved knowledge" .

:CONFLICT_BANK :addresses :EmbeddedKnowledgeConflicts ;
    :contextText "(ii) conflicts within the models’ encoded knowledge" .

:CONFLICT_BANK :addresses :InterplayOfConflictForms ;
    :contextText "(iii)the interplay between these conflict forms." .

:CONFLICT_BANK :covers :MisinformationConflict ;
    :contextText "including inaccurate information (misinformation conflict)" .

:CONFLICT_BANK :covers :TemporalConflict ;
    :contextText "knowledge changes over time (temporal conflict)" .

:CONFLICT_BANK :covers :SemanticConflict ;
    :contextText "the polysemic nature of language (semantic conflict)" .

:CONFLICT_BANK :contains "7453853 claim-evidence pairs" ;
    :contextText "we create a total of 7,453,853 claim-evidence pairs." .

:CONFLICT_BANK :contains "553117 QA pairs" ;
    :contextText "Additionally, we construct 553,117 QA pairs" .

:CONFLICT_BANK :contains "2863205 claims" ;
    :contextText "we collect 2,863,205 claims from Wikidata" .

:CONFLICT_BANK :includesTextStyle :WikipediaStyle ;
    :contextText "we produce three types of textual styles: Wikipedia, book, and news." .

:CONFLICT_BANK :includesTextStyle :BookStyle ;
    :contextText "we produce three types of textual styles: Wikipedia, book, and news." .

:CONFLICT_BANK :includesTextStyle :NewsStyle ;
    :contextText "we produce three types of textual styles: Wikipedia, book, and news." .

:CONFLICT_BANK :basedOn :Wikidata_2024_04_02 ;
    :contextText "We utilize the Wikidata [Vrande ˇci´c and Krötzsch, 2014] dump of April 02, 2024, as the knowledge source" .

:CONFLICT_BANK :uses :QuintupletRepresentation ;
    :contextText "transforming knowledge triples and qualifiers into a quintuplet format: (s, r, o, s d, od)" .

:CONFLICT_BANK :uses "top 100 most frequent relations" ;
    :contextText "we focus on the top 100 most frequent relations" .

:CONFLICT_BANK :uses :Meta-Llama-3-70B-Instruct ;
    :contextText "We use the LLAMA-3-70B-I NSTRUCT model for all evidence and description generation" .

:CONFLICT_BANK :applies :FeatureFiltering ;
    :contextText "feature filtering" .

:CONFLICT_BANK :uses :DeBERTaV2_xxlarge_mnli ;
    :contextText "we employ the state-of-the-art NLI model DeBERTa-V25to rigorously assess the relationship between the generated evidence and the claims." .

:CONFLICT_BANK :uses :SBERT_all-mpnet-base-v2 ;
    :contextText "we utilize the SBERT6to compute embeddings for all evidence" .

:ConflictConfirmationClassifier :achievesScore "over 95% accuracy" ;
    :contextText "we manually evaluate 200 random examples and observe over 95% accuracy of the model." .

:CONFLICT_BANK :filtersOut :NonConflictingEvidencePairs ;
    :contextText "We filter out all evidence pairs identified as non-conflicting by the classifier to ensure the quality of our dataset." .

:CONFLICT_BANK :releasedAs :PythonPackage ;
    :contextText "we release a Python package that automates data loading, baseline evaluation, and training3." .

:CONFLICT_BANK :publishedIn :HFDataset_CB_claim_evidence ;
